# !/bin/zsh -e

setopt autocd
setopt magic_equal_subst
setopt hist_ignore_dups
setopt no_beep
setopt no_histbeep
setopt no_listbeep

# editor
export EDITOR=nvim

# path
export PATH=$PATH:$HOME/.cargo/bin

# prompt
precmd() { printf '\n' }
setopt prompt_subst
source ~/dotfiles/src/zsh/git-prompt.sh
export PROMPT=$'%* [%n@%m: %F{green}%~%f]%F{yellow}$(__git_ps1 " (%s)")%f\n\$ '

# zsh-completions
FPATH=$(brew --prefix)/share/zsh-completions:$FPATH
FPATH=~/.zsh/completion:$FPATH
autoload bashcompinit && bashcompinit
autoload -Uz compinit && compinit

complete -C "$(which aws_completer)" aws

zstyle ':completion:*:default' menu select=2

# language
export LANG=ja_JP.UTF-8

# history
export HISTFILE=$HOME/.zsh_history
export HISTSIZE=1000
export SAVEHIST=1000

# asdf
. $(brew --prefix asdf)/libexec/asdf.sh

# direnv
eval "$(direnv hook zsh)"

# kubectl
source <(kubectl completion zsh)

# krew
export PATH="$HOME/.krew/bin:$PATH"

# alias
alias cdd='cd ~/dotfiles'
alias cde='cd ~/environment'
alias d='docker'
alias dc='docker compose'
alias g='git'
alias gad='git add'
alias gbr='git branch'
alias gcom='git commit -m'
alias gcomv='git commit -v'
alias gdi='git diff'
alias gfe='git fetch'
alias glo='git log --pretty=oneline'
alias gst='git status'
alias gsw='git switch'
alias gre='git reset'
alias grest='git restore'
alias gdem="git branch --merged|egrep -v '\*|develop|master|main'|xargs git branch -d"
alias grep='grep --color=auto'
alias k='kubectl'
alias l='exa -1'
alias la='exa -1a'
alias ll='exa -l'
alias lla='exa -al'
alias mkdir='mkdir -p'
alias mv='mv -i'
alias rm='trash-put'
alias v='nvim'
alias vi='nvim'

# imagemagick@6
export PATH="$(brew --prefix imagemagick@6)/bin:$PATH"
export LDFLAGS="-L$(brew --prefix imagemagick@6)/lib"
export CPPFLAGS="-I$(brew --prefix imagemagick@6)/include"
export PKG_CONFIG_PATH="$(brew --prefix imagemagick@6)/lib/pkgconfig"

if [ -f "$HOME/google-cloud-sdk/path.zsh.inc" ]; then . "$HOME/google-cloud-sdk/path.zsh.inc"; fi
if [ -f "$HOME/google-cloud-sdk/completion.zsh.inc" ]; then . "$HOME/google-cloud-sdk/completion.zsh.inc"; fi

source <(kubectl completion zsh)
