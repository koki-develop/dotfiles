taps = %w[
  go-task/tap
  goreleaser/tap
  jdxcode/tap
  koki-develop/tap
  jesseduffield/lazygit
  wez/wezterm
]

casks = %w[
  aws-vault
  clipy
  deepl
  docker
  google-japanese-ime
  hammerspoon
  obsidian
  slack
  todoist
  visual-studio-code
  wez/wezterm/wezterm
]

formulae = %w[
  actionlint
  awscli
  bottom
  colordiff
  direnv
  exa
  fd
  genact
  gh
  git
  git-delta
  git-secrets
  go-task/tap/go-task
  goreleaser/tap/goreleaser
  hyperfine
  jdxcode/tap/rtx
  jq
  libpq
  mysql-client
  koki-develop/tap/clive
  koki-develop/tap/ego
  koki-develop/tap/docker-tags
  koki-develop/tap/gat
  koki-develop/tap/gofzf
  koki-develop/tap/gotrash
  koki-develop/tap/typingo
  jesseduffield/lazygit/lazygit
  neovim
  procs
  ripgrep
  starship
  watch
  watchexec
  wget
  xh
]

taps.each { |t| tap t }
casks.each { |c| cask c }
formulae.each { |f| brew f }
