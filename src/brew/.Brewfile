taps = %w[
  aquaproj/aqua
  go-task/tap
  goreleaser/tap
  koki-develop/tap
  jesseduffield/lazygit
  wez/wezterm
]

casks = %w[
  aws-vault
  deepl
  docker
  hiddenbar
  google-japanese-ime
  raycast
  slack
  todoist
  visual-studio-code
  wez/wezterm/wezterm
]

formulae = %w[
  actionlint
  aquaproj/aqua/aqua
  awscli
  bottom
  colordiff
  direnv
  eza
  fd
  genact
  gh
  git
  git-delta
  git-secrets
  glow
  go-task/tap/go-task
  golangci-lint
  goreleaser/tap/goreleaser
  gpg
  hyperfine
  imagemagick
  jq
  libpq
  mise
  mysql-client
  koki-develop/tap/askai
  koki-develop/tap/clive
  koki-develop/tap/ego
  koki-develop/tap/docker-tags
  koki-develop/tap/gat
  koki-develop/tap/gofzf
  koki-develop/tap/gotrash
  koki-develop/tap/typingo
  jesseduffield/lazygit/lazygit
  neovim
  procs
  ripgrep
  starship
  watch
  watchexec
  wget
  xh
]

taps.each { |t| tap t }
casks.each { |c| cask c }
formulae.each { |f| brew f }
